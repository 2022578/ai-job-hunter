# GenAI Job Assistant Environment Variables
# Copy this file to .env and fill in your actual values

# Encryption Key (Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# If not set, a new key will be automatically generated and saved to .env
ENCRYPTION_KEY=your-encryption-key-here

# Naukri.com Credentials (Optional - can be configured in UI)
NAUKRI_EMAIL=your-naukri-email@example.com
NAUKRI_PASSWORD=your-naukri-password

# Email Notification Settings (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=your-email@example.com
EMAIL_TO=your-email@example.com

# Twilio WhatsApp Settings (Optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
USER_WHATSAPP_NUMBER=whatsapp:+91your-phone-number

# News API (Optional - for company profiling)
NEWS_API_KEY=your-news-api-key

# Glassdoor API (Optional - for company profiling)
GLASSDOOR_API_KEY=your-glassdoor-api-key

# Ollama Settings (Optional - defaults to localhost)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Database Path (Optional - defaults to data/job_assistant.db)
DATABASE_PATH=data/job_assistant.db

# Logging Level (Optional - defaults to INFO)
LOG_LEVEL=INFO
